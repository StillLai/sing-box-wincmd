# sing-box-wincmd 配置文件
# 复制此文件为 config.env 并填入你的实际配置
# copy config.env.example config.env

# Mixed 模式配置文件的完整下载地址
MIXED_SUB_URL=https://gist.githubusercontent.com/username/gist_id/raw/filename.json

# TUN 模式配置文件的完整下载地址
TUN_SUB_URL=https://gist.githubusercontent.com/username/gist_id/raw/filename.json

# GitHub 下载代理前缀 (用于内核下载加速)
# 国内用户建议保留默认值，无需代理可留空
PROXY_PREFIX=https://ghfast.top/