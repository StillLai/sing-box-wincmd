# sing-box-wincmd 配置文件
# 复制此文件为 config.env 并填入你的实际配置
# cp config.env.example config.env

# Gist 订阅地址 (格式: username/gist_id)
# 在此 Gist 中存放你的 sing-box 配置文件
# 需要包含以下文件:
#   - config_noTun.json  (Mixed 模式配置)
#   - config_tun.json    (TUN 模式配置)
GIST_ID=your_github_username/your_gist_id

# GitHub 下载代理前缀 (用于内核和订阅下载加速)
# 国内用户建议保留默认值，无需代理可留空
PROXY_PREFIX=https://gh-proxy.org/